getWifiDeviceName() {
  nmcli d | grep wifi | head -n 1 | sed 's/ \+/ /g' | cut -d ' ' -f 1
}

getEtherDeviceName() {
  nmcli d | grep ethernet | head -n 1 | sed 's/ \+/ /g' | cut -d ' ' -f 1
}

getNetDeviceInfo() {
  nmcli d show ${1} | grep "${2}" | sed 's/ \+/ /g' | cut -d ' ' -f 2
}

getNetiDeviceType() {
  getNetDeviceInfo ${1} GENERAL.TYPE
}

getNetDeviceState() {
  local state=`getNetDeviceInfo ${1} GENERAL.STATE`
  if [ ${state} -eq 100 ]
  then
    echo "connected"
  else
    echo "dicsonnected"
  fi
}

getNetDeviceAddress() {
  getNetDeviceInfo ${1} "IP4\.ADDRESS\[1\]"
}

getNetDeviceGeneralConnection() {
  getNetDeviceInfo ${1} GENERAL.CONNECTION
}

getWifiInfo() {
  nmcli dev wifi | grep ${1} | head -n 1 | sed 's/ \+/ /g' | cut -d ' ' -f ${2}
}

getWifiStatus() {
  getNetDeviceState `getWifiDeviceName`
}

getWifiAccessPoint() {
  getNetDeviceGeneralConnection `getWifiDeviceName`
}

getWifiBitRate() {
  getWifiInfo `getWifiAccessPoint` 6
}

getWifiSignalLevel() {
  getWifiInfo `getWifiAccessPoint` 8
}

getWifiIpAddress() {
  getNetDeviceAddress `getWifiDeviceName`
}

getEtherStatus() {
  getNetDeviceState `getEtherDviceName`
}

getEtherIpAddress() {
  getNetDeviceAddress `getEtherDeviceName`
}
