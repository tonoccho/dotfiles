#!/usr/bin/env zsh

source ${HOME}/.zshrc_func/800_myfuncs
source ${HOME}/.zshrc_func/100_logging

isGitRepository() {
  [ -d .git ] || git rev-parse --git-dir > /dev/null 2>&1
  echo $?
}

gitBranchName() {
  git branch --contains=HEAD | cut -d ' ' -f 2
}

gitModifiedCount() {
  git status --short | grep -e ".M" | wc -l
}

gitNewFileCount(){
  git status --short | grep "A." | wc -l
}

gitUnstagedCount() {
  git status --short | grep "??" | wc -l
}

gitStashSize() {
  echo $((`git stash list | wc -l` - 1))
}

gitAheadCount() {
  git branch -v | grep 'ahead' | sed -r 's/[ *]\s(\S*).*(\[(ahead|behind).+?\]).*/\1 \2/g'
}

gitBehindCount() {
  git branch -v | grep 'behind' | sed -r 's/[ *]\s(\S*).*(\[(ahead|behind).+?\]).*/\1 \2/g'
}

gitRepositoryInfo() {
  if [ `isGitRepository` -eq 0 ]
  then
    echo "¯£Ñ`gitBranchName` ´üä `gitModifiedCount` ´æù `gitNewFileCount` ´ä¿ `gitUnstagedCount` ´à¼ `gitStashSize`"
  fi
}

gitRepositoryInfo
